# ==============================================================================
# AI Trader — .env
# 2026-04-12 - Configurazione Grid Trading Bot
# Copia questo file in .env e personalizza i valori
# ==============================================================================

# --- Ambiente ---
PROJECT_ENV=dev

# --- Trading Mode ---
# "testnet" = Binance Testnet (soldi finti)
# "dry_run" = Simula senza ordini
# "mainnet" = SOLDI REALI (attenzione!)
TRADING_MODE=testnet
INITIAL_CAPITAL=55.0
MAX_ORDER_USDT=10.0
WHITELIST_PAIRS=DOGEUSDT,XRPUSDT
CYCLE_INTERVAL_SEC=30

# --- Grid Trading ---
GRID_LEVELS=8
GRID_ALLOCATION_PCT=0.80

# --- Ollama (AI opzionale) ---
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=gemma2:9b
OLLAMA_TIMEOUT=120

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Binance Testnet ---
# Ottieni le chiavi da: https://testnet.binance.vision/
BINANCE_TESTNET_ENABLED=true
BINANCE_TESTNET_API_KEY=your_testnet_api_key
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision
BINANCE_TESTNET_WS_URL=wss://stream.testnet.binance.vision/ws

# --- Binance Mainnet (SOLO per trading reale) ---
# BINANCE_MAINNET_API_KEY=
# BINANCE_MAINNET_API_SECRET=
# BINANCE_MAINNET_BASE_URL=https://api.binance.com
